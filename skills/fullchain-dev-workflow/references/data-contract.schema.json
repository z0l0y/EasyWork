{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://easywork.dev/data-contract.schema.json",
  "title": "EasyWork Data Contract",
  "description": "Machine-readable JSON Schema for EasyWork step output validation. Generated from data-contract.md v2.5.",
  "type": "object",
  "properties": {
    "easywork_version": {
      "type": "string",
      "description": "EasyWork 版本号"
    },
    "task_type": {
      "type": "string",
      "enum": [
        "纯理解",
        "纯审查",
        "纯文档",
        "微调",
        "Bug修复",
        "重构",
        "功能开发"
      ]
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "低",
        "中",
        "高"
      ]
    },
    "read_output": {
      "type": "object",
      "required": [
        "goal",
        "scope",
        "constraints",
        "acceptance_criteria",
        "non_goals"
      ],
      "properties": {
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "object",
          "required": [
            "files",
            "modules"
          ],
          "properties": {
            "files": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            },
            "modules": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            }
          }
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "acceptance_criteria": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "non_goals": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 0
        },
        "clarifications": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "code_output": {
      "type": "object",
      "required": [
        "files_changed",
        "impact_assessment",
        "implementation_notes"
      ],
      "properties": {
        "files_changed": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "path",
              "change_type",
              "reason"
            ],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "change_type": {
                "type": "string",
                "enum": [
                  "add",
                  "modify",
                  "delete"
                ]
              },
              "lines_estimated": {
                "type": "integer",
                "minimum": 1
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "new_dependencies": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "version",
              "why_necessary"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "version": {
                "type": "string"
              },
              "why_necessary": {
                "type": "string"
              }
            }
          }
        },
        "impact_assessment": {
          "type": "string",
          "minLength": 1
        },
        "implementation_notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "review_output": {
      "type": "object",
      "required": [
        "verdict",
        "dimensions",
        "blocking_issues"
      ],
      "properties": {
        "verdict": {
          "type": "string",
          "enum": [
            "pass",
            "pass_with_fixes",
            "blocked"
          ]
        },
        "dimensions": {
          "type": "object",
          "required": [
            "correctness",
            "security",
            "compatibility",
            "maintainability",
            "performance",
            "observability",
            "accessibility"
          ],
          "properties": {
            "correctness": {
              "$ref": "#/$defs/dimension"
            },
            "security": {
              "$ref": "#/$defs/dimension"
            },
            "compatibility": {
              "$ref": "#/$defs/dimension"
            },
            "maintainability": {
              "$ref": "#/$defs/dimension"
            },
            "performance": {
              "$ref": "#/$defs/dimension"
            },
            "observability": {
              "$ref": "#/$defs/dimension"
            },
            "accessibility": {
              "$ref": "#/$defs/dimension"
            }
          }
        },
        "blocking_issues": {
          "type": "integer",
          "minimum": 0
        },
        "fixes_applied": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "supply_chain_check": {
          "type": "object",
          "properties": {
            "checked": {
              "type": "boolean"
            },
            "findings": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "parallel_reviews": {
          "type": "object",
          "properties": {
            "security_reviewer": {
              "$ref": "#/$defs/parallel_review_result"
            },
            "performance_reviewer": {
              "$ref": "#/$defs/parallel_review_result"
            },
            "compatibility_reviewer": {
              "$ref": "#/$defs/parallel_review_result"
            }
          }
        },
        "cross_check": {
          "type": "object",
          "properties": {
            "dimensions_checked": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "verdict": {
              "type": "string",
              "enum": [
                "一致",
                "发现新问题"
              ]
            },
            "findings": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "examine_output": {
      "type": "object",
      "required": [
        "verdict",
        "test_command",
        "test_results",
        "test_output_snippet"
      ],
      "properties": {
        "verdict": {
          "type": "string",
          "enum": [
            "pass",
            "conditional_pass",
            "fail"
          ]
        },
        "test_command": {
          "type": "string",
          "minLength": 1
        },
        "test_results": {
          "type": "object",
          "required": [
            "total",
            "passed",
            "failed",
            "skipped"
          ],
          "properties": {
            "total": {
              "type": "integer",
              "minimum": 0
            },
            "passed": {
              "type": "integer",
              "minimum": 0
            },
            "failed": {
              "type": "integer",
              "minimum": 0
            },
            "skipped": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "new_tests_added": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "file",
              "description",
              "covers"
            ],
            "properties": {
              "file": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "covers": {
                "type": "string"
              }
            }
          }
        },
        "test_output_snippet": {
          "type": "string",
          "minLength": 1
        },
        "uncovered_scenarios": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "git_output": {
      "type": "object",
      "required": [
        "total_files",
        "total_units",
        "units"
      ],
      "properties": {
        "total_files": {
          "type": "integer",
          "minimum": 1
        },
        "total_units": {
          "type": "integer",
          "minimum": 1
        },
        "units": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "index",
              "dimension",
              "files",
              "summary",
              "risk_level",
              "risk_detail",
              "verification",
              "commit_message",
              "business_context",
              "risk_introduced",
              "verification_evidence",
              "developer_checklist"
            ],
            "properties": {
              "index": {
                "type": "integer"
              },
              "dimension": {
                "type": "string",
                "enum": [
                  "config",
                  "logic",
                  "ui",
                  "test_docs"
                ]
              },
              "files": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "minItems": 1
              },
              "summary": {
                "type": "string",
                "minLength": 1
              },
              "risk_level": {
                "type": "string",
                "enum": [
                  "low",
                  "medium",
                  "high"
                ]
              },
              "risk_detail": {
                "type": "string",
                "minLength": 1
              },
              "verification": {
                "type": "string",
                "minLength": 1
              },
              "commit_message": {
                "type": "object",
                "required": [
                  "type",
                  "subject"
                ],
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": [
                      "feat",
                      "fix",
                      "refactor",
                      "test",
                      "docs",
                      "style",
                      "chore",
                      "perf",
                      "ci"
                    ]
                  },
                  "scope": {
                    "type": "string"
                  },
                  "subject": {
                    "type": "string",
                    "minLength": 1
                  },
                  "body": {
                    "type": "string"
                  }
                }
              },
              "business_context": {
                "type": "string",
                "minLength": 1
              },
              "risk_introduced": {
                "type": "string",
                "minLength": 1
              },
              "verification_evidence": {
                "type": "string",
                "minLength": 1
              },
              "developer_checklist": {
                "type": "object",
                "required": [
                  "scope_correct",
                  "no_side_effects",
                  "test_coverage",
                  "style_consistent",
                  "docs_updated"
                ],
                "properties": {
                  "scope_correct": {
                    "type": "boolean"
                  },
                  "no_side_effects": {
                    "type": "boolean"
                  },
                  "test_coverage": {
                    "type": "boolean"
                  },
                  "style_consistent": {
                    "type": "boolean"
                  },
                  "docs_updated": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "mixed_files_warning": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "graph_output": {
      "type": "object",
      "required": [
        "diagram_type",
        "mermaid_code",
        "node_mapping",
        "text_explanation"
      ],
      "properties": {
        "diagram_type": {
          "type": "string",
          "enum": [
            "flowchart",
            "sequence",
            "architecture"
          ]
        },
        "mermaid_code": {
          "type": "string",
          "minLength": 1
        },
        "node_mapping": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "node",
              "entity",
              "location"
            ],
            "properties": {
              "node": {
                "type": "string"
              },
              "entity": {
                "type": "string"
              },
              "location": {
                "type": "string"
              }
            }
          }
        },
        "text_explanation": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "sum_output": {
      "type": "object",
      "required": [
        "background",
        "discovery",
        "problem",
        "solution",
        "outcome",
        "future",
        "skipped_steps"
      ],
      "properties": {
        "background": {
          "type": "string",
          "minLength": 1
        },
        "discovery": {
          "type": "string",
          "minLength": 1
        },
        "problem": {
          "type": "string",
          "minLength": 1
        },
        "solution": {
          "type": "string",
          "minLength": 1
        },
        "outcome": {
          "type": "object",
          "required": [
            "acceptance_check"
          ],
          "properties": {
            "test_results_ref": {
              "type": "string"
            },
            "acceptance_check": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            },
            "metrics": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "before": {
                    "type": "string"
                  },
                  "after": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "future": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "skipped_steps": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 0
        }
      }
    },
    "talk_output": {
      "type": "object",
      "required": [
        "five_whys",
        "root_cause",
        "root_cause_type",
        "trade_offs",
        "engineering_rules"
      ],
      "properties": {
        "five_whys": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "level",
              "question",
              "answer"
            ],
            "properties": {
              "level": {
                "type": "integer"
              },
              "question": {
                "type": "string"
              },
              "answer": {
                "type": "string"
              }
            }
          }
        },
        "root_cause": {
          "type": "string",
          "minLength": 1
        },
        "root_cause_type": {
          "type": "string",
          "enum": [
            "process",
            "tooling",
            "knowledge",
            "design"
          ]
        },
        "trade_offs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "item",
              "benefit",
              "cost",
              "intentional",
              "followup"
            ],
            "properties": {
              "item": {
                "type": "string"
              },
              "benefit": {
                "type": "string"
              },
              "cost": {
                "type": "string"
              },
              "intentional": {
                "type": "boolean"
              },
              "followup": {
                "type": "string"
              }
            }
          }
        },
        "engineering_rules": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      }
    },
    "ask_output": {
      "type": "object",
      "required": [
        "questions",
        "confirmed_dimensions"
      ],
      "properties": {
        "questions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "dimension",
              "question",
              "why_asked",
              "if_no_action"
            ],
            "properties": {
              "dimension": {
                "type": "string",
                "enum": [
                  "scope",
                  "behavior",
                  "data",
                  "security",
                  "test",
                  "deploy"
                ]
              },
              "question": {
                "type": "string"
              },
              "why_asked": {
                "type": "string"
              },
              "if_no_action": {
                "type": "string"
              }
            }
          }
        },
        "confirmed_dimensions": {
          "type": "integer",
          "minimum": 0
        },
        "pending_dimensions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "user_skip_note": {
          "type": "string"
        }
      }
    },
    "git_tracking": {
      "type": "object",
      "properties": {
        "task_description": {
          "type": "string"
        },
        "task_date": {
          "type": "string"
        },
        "task_type": {
          "type": "string"
        },
        "risk_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "units": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "examine_result": {
          "type": "object",
          "properties": {
            "test_command": {
              "type": "string"
            },
            "test_total": {
              "type": "integer"
            },
            "test_passed": {
              "type": "integer"
            },
            "test_failed": {
              "type": "integer"
            },
            "test_skipped": {
              "type": "integer"
            },
            "verdict": {
              "type": "string"
            }
          }
        }
      }
    },
    "output_backend": {
      "type": "object",
      "required": [
        "format",
        "name"
      ],
      "properties": {
        "format": {
          "type": "string",
          "enum": [
            "html",
            "markdown",
            "lark_doc"
          ]
        },
        "name": {
          "type": "string"
        },
        "share_link": {
          "type": "string"
        }
      }
    }
  },
  "$defs": {
    "dimension": {
      "type": "object",
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "pass",
            "issues_found",
            "not_applicable"
          ]
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "parallel_review_result": {
      "type": "object",
      "required": [
        "verdict",
        "blocking_count",
        "findings"
      ],
      "properties": {
        "verdict": {
          "type": "string",
          "enum": [
            "pass",
            "issues_found"
          ]
        },
        "blocking_count": {
          "type": "integer",
          "minimum": 0
        },
        "findings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}